---
const services = [
  {
    title: 'Solar Energy',
    slug: 'solar',
    description: 'Photovoltaic systems for rooftop and utility-scale installations. From 5 kW residential to 100 MW utility farms.',
    photo: '/images/slideshow/solar-energy-panels.jpg',
    accent: 'var(--color-amber)',
    accentLight: 'var(--color-amber-light)',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="5"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>`,
  },
  {
    title: 'Wind Turbines',
    slug: 'wind',
    description: 'Onshore and offshore wind farm development, from resource assessment to full commissioning and O&M.',
    photo: '/images/slideshow/aerial-view-of-part-of-windmill-turbine-in-countryside-green-energy.jpg',
    accent: 'var(--color-blue)',
    accentLight: 'var(--color-blue-light)',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v20M8 6l4-4 4 4M8 18l4 4 4-4"/><circle cx="12" cy="12" r="2"/><path d="M4 12h16"/></svg>`,
  },
  {
    title: 'Hydroelectric',
    slug: 'hydro',
    description: 'Small and large-scale hydropower plants leveraging rivers, dams and run-of-river installations.',
    photo: '/images/slideshow/valvestino-dam-in-italy-hydroelectric-power-plant-.jpg',
    accent: 'var(--color-blue)',
    accentLight: 'var(--color-blue-light)',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 8v4l3 3"/></svg>`,
  },
  {
    title: 'Geothermal',
    slug: 'geothermal',
    description: 'Harnessing Earth\'s internal heat for electricity generation and direct heating applications.',
    photo: '/images/slideshow/Geothermal_Power_Plants.png',
    accent: 'var(--color-primary)',
    accentLight: 'var(--color-primary-light)',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22V12M12 12C12 6.477 7.523 2 2 2"/><path d="M12 12c0-5.523 4.477-10 10-10"/><path d="M3 21s2-3 4-3 3 3 5 3 3-3 5-3 4 3 4 3"/></svg>`,
  },
  {
    title: 'Waste-to-Energy',
    slug: 'waste-to-energy',
    description: 'Converting municipal and industrial waste streams into clean electricity and heat through advanced combustion.',
    photo: '/images/slideshow/wte_plant.png',
    accent: 'var(--color-primary)',
    accentLight: 'var(--color-primary-light)',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 8C8 10 5.9 16.17 3.82 19.11c-.98 1.39-.63 2.89.5 2.89H19.5c1.13 0 1.48-1.5.5-2.89C17.9 16.17 16 12 16 8"/><path d="M12 2c1 2.5.5 4-1 6.5"/></svg>`,
  },
  {
    title: 'Energy Consulting',
    slug: 'consulting',
    description: 'Feasibility studies, grid connection analysis, permitting, and investment optimization for your energy project.',
    photo: '/images/site/energy-consulting.jpg',
    accent: 'var(--color-amber)',
    accentLight: 'var(--color-amber-light)',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  },
];
---

<section id="services" class="py-24 lg:py-32" style="background: var(--color-surface)">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Heading -->
    <div class="text-center mb-16 reveal">
      <span
        class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-4"
        style="background: var(--color-amber-light); color: var(--color-amber-dark)"
      >Our Services</span>
      <h2 class="text-4xl md:text-5xl font-800 mb-4 leading-snug" style="color: var(--color-dark)">
        Complete Renewable<br /><span class="text-gradient">Energy Solutions</span>
      </h2>
      <p class="max-w-xl mx-auto text-lg" style="color: var(--color-muted)">
        From initial concept to long-term operation, we cover every stage of your renewable energy project.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, i) => (
        <div
          class="card-hover rounded-2xl bg-white reveal"
          style={`transition-delay: ${i * 80}ms; border: 1px solid rgba(13,27,42,0.07)`}
        >
          <!-- Photo background top -->
          <div class="relative h-44 overflow-hidden rounded-t-2xl">
            <img
              src={service.photo}
              alt={service.title}
              class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 40%, rgba(13,27,42,0.35) 100%)" />
            <!-- Icon badge -->
            <div
              class="absolute top-4 left-4 w-12 h-12 rounded-xl flex items-center justify-center text-white shadow-lg"
              style={`background: ${service.accent}`}
              set:html={service.icon}
            />
          </div>

          <!-- Text content -->
          <div class="p-6">
            <h3 class="text-xl font-700 mb-2 leading-snug" style="color: var(--color-dark)">{service.title}</h3>
            <p class="text-sm leading-relaxed mb-4" style="color: var(--color-muted)">{service.description}</p>
            <a
              href={`/services/${service.slug}`}
              class="inline-flex items-center gap-1.5 text-sm font-600 transition-all hover:gap-2.5"
              style={`color: ${service.accent}`}
            >
              Learn more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
