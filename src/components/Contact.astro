---
import { useTranslations } from '../i18n/ui';
import { defaultLang } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

export interface Props { lang?: Lang; }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="relative py-24 lg:py-32 overflow-hidden">

  <!-- Background photo with overlay -->
  <div
    class="absolute inset-0 bg-cover bg-center"
    style="background-image: url('/images/slideshow/solar-energy-panels.jpg')"
  />
  <div
    class="absolute inset-0"
    style="background: linear-gradient(135deg, rgba(245,247,250,0.96) 0%, rgba(245,247,250,0.93) 60%, rgba(232,68,21,0.06) 100%)"
  />

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Left: info -->
      <div class="reveal">
        <span
          class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-4"
          style="background: rgba(249,168,0,0.12); color: var(--color-amber-dark)"
        >{t('contact.badge')}</span>
        <h2 class="text-4xl md:text-5xl font-800 mb-5 leading-snug" style="color: var(--color-dark)">
          {t('contact.title1')}<br /><span class="text-gradient">{t('contact.title2')}</span>
        </h2>
        <p class="text-lg mb-10" style="color: var(--color-muted)">
          {t('contact.subtitle')}
        </p>

        <!-- Contact details -->
        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 text-white"
              style="background: var(--color-primary)"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="font-600" style="color: var(--color-dark)">{t('contact.labelOffice')}</p>
              <p class="text-sm" style="color: var(--color-muted)">Savska cesta 41, 10000 Zagreb, Croatia</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 text-white"
              style="background: var(--color-primary)"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="font-600" style="color: var(--color-dark)">{t('contact.email')}</p>
              <a href="mailto:info@renervision.com" class="text-sm hover:underline" style="color: var(--color-primary)">
                info@renervision.com
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 text-white"
              style="background: var(--color-primary)"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <p class="font-600" style="color: var(--color-dark)">{t('contact.labelPhone')}</p>
              <a href="tel:+48733301364" class="text-sm hover:underline block" style="color: var(--color-primary)">
                +48 733 301 364
              </a>
              <a href="tel:+37064532993" class="text-sm hover:underline block" style="color: var(--color-primary)">
                +370 645 32993
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 text-white"
              style="background: var(--color-blue)"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
              </svg>
            </div>
            <div>
              <p class="font-600" style="color: var(--color-dark)">{t('contact.workingHours')}</p>
              <p class="text-sm" style="color: var(--color-muted)">{t('contact.workingHoursVal')}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div
        class="bg-white rounded-3xl p-8 lg:p-10 reveal"
        style="border: 1px solid rgba(13,27,42,0.08); box-shadow: 0 24px 64px rgba(232,68,21,0.10)"
      >
        <h3 class="text-2xl font-700 mb-6 leading-snug" style="color: var(--color-dark)">{t('contact.formTitle')}</h3>
        <form class="space-y-5" novalidate>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-500 mb-1.5" style="color: var(--color-text)">{t('contact.name')} *</label>
              <input
                type="text"
                placeholder={t('contact.namePlaceholder')}
                required
                class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all"
                style="border: 1.5px solid #E5E8ED; background: var(--color-surface); color: var(--color-dark)"
                onfocus="this.style.borderColor='#E84415'"
                onblur="this.style.borderColor='#E5E8ED'"
              />
            </div>
            <div>
              <label class="block text-sm font-500 mb-1.5" style="color: var(--color-text)">{t('contact.company')}</label>
              <input
                type="text"
                placeholder={t('contact.companyPlaceholder')}
                class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all"
                style="border: 1.5px solid #E5E8ED; background: var(--color-surface); color: var(--color-dark)"
                onfocus="this.style.borderColor='#E84415'"
                onblur="this.style.borderColor='#E5E8ED'"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-500 mb-1.5" style="color: var(--color-text)">{t('contact.email')} *</label>
              <input
                type="email"
                placeholder={t('contact.emailPlaceholder')}
                required
                class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all"
                style="border: 1.5px solid #E5E8ED; background: var(--color-surface); color: var(--color-dark)"
                onfocus="this.style.borderColor='#E84415'"
                onblur="this.style.borderColor='#E5E8ED'"
              />
            </div>
            <div>
              <label class="block text-sm font-500 mb-1.5" style="color: var(--color-text)">{t('contact.labelPhone')}</label>
              <input
                type="tel"
                placeholder="+48 ..."
                class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all"
                style="border: 1.5px solid #E5E8ED; background: var(--color-surface); color: var(--color-dark)"
                onfocus="this.style.borderColor='#E84415'"
                onblur="this.style.borderColor='#E5E8ED'"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-500 mb-1.5" style="color: var(--color-text)">{t('contact.labelProject')}</label>
            <select
              class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all appearance-none"
              style="border: 1.5px solid #E5E8ED; background: var(--color-surface); color: var(--color-dark)"
              onfocus="this.style.borderColor='#E84415'"
              onblur="this.style.borderColor='#E5E8ED'"
            >
              <option value="">{t('contact.selectService')}</option>
              <option>{t('services.solar.title')}</option>
              <option>{t('services.wind.title')}</option>
              <option>{t('services.hydro.title')}</option>
              <option>{t('services.geo.title')}</option>
              <option>{t('services.wte.title')}</option>
              <option>{t('services.cons.title')}</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-500 mb-1.5" style="color: var(--color-text)">{t('contact.message')} *</label>
            <textarea
              rows="4"
              placeholder={t('contact.messagePlaceholder')}
              required
              class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all resize-none"
              style="border: 1.5px solid #E5E8ED; background: var(--color-surface); color: var(--color-dark)"
              onfocus="this.style.borderColor='#E84415'"
              onblur="this.style.borderColor='#E5E8ED'"
            />
          </div>

          <button
            type="submit"
            class="w-full py-3.5 rounded-xl text-sm font-600 text-white transition-all hover:scale-[1.02] hover:shadow-lg active:scale-[0.98]"
            style="background: var(--color-primary)"
          >
            {t('contact.submitBtn')}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
