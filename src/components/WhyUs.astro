---
const features = [
  {
    title: 'End-to-End Delivery',
    description: 'We manage every phase: from feasibility and permitting through construction and long-term O&M.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: 'EU Market Expertise',
    description: 'Deep knowledge of European energy regulations, incentive schemes, and grid connection requirements.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/></svg>`,
  },
  {
    title: 'Certified Engineers',
    description: 'Our team holds international certifications and brings over 15 years of hands-on project experience.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15l-3 6 3-1 3 1-3-6z"/><path d="M12 15a7 7 0 100-14 7 7 0 000 14z"/></svg>`,
  },
  {
    title: 'Transparent Reporting',
    description: 'Real-time monitoring dashboards and monthly performance reports keep you informed at every step.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  },
];
---

<section id="why-us" class="py-24 lg:py-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: photo with overlay card -->
      <div class="relative reveal">
        <!-- Main photo -->
        <div class="rounded-3xl overflow-hidden shadow-2xl" style="box-shadow: 0 32px 64px rgba(232,68,21,0.15)">
          <img
            src="/images/site/engineer-tablet.jpg"
            alt="Engineer with tablet at wind farm"
            class="w-full h-[480px] object-cover"
            loading="lazy"
          />
          <!-- Light overlay -->
          <div
            class="absolute inset-0 rounded-3xl"
            style="background: linear-gradient(to top, rgba(10,43,30,0.25) 0%, transparent 60%)"
          />
        </div>

      </div>

      <!-- Right: text content -->
      <div>
        <div class="reveal">
          <span
            class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-4"
            style="background: rgba(249,168,0,0.12); color: var(--color-amber-dark)"
          >Why Choose Us</span>
          <h2 class="text-4xl md:text-5xl font-800 mb-5 leading-snug" style="color: var(--color-dark)">
            Your Trusted Partner in<br /><span class="text-gradient">Clean Energy</span>
          </h2>
          <p class="text-lg mb-10" style="color: var(--color-muted)">
            With over a decade of experience across Europe, RENERVISION brings technical excellence,
            regulatory expertise and a commitment to sustainability to every project.
          </p>
        </div>

        <!-- Feature list -->
        <div class="grid gap-5">
          {features.map((f, i) => (
            <div
              class="flex gap-4 items-start p-4 rounded-xl reveal"
              style={`background: var(--color-surface); transition-delay: ${i * 100}ms`}
            >
              <div
                class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5 text-white"
                style="background: var(--color-primary)"
                set:html={f.icon}
              />
              <div>
                <h3 class="font-700 mb-1" style="color: var(--color-dark)">{f.title}</h3>
                <p class="text-sm leading-relaxed" style="color: var(--color-muted)">{f.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
