---
const stats = [
  { value: '50%', label: 'Share of renewables in EU electricity (H1 2024)' },
  { value: '120+', label: 'Projects delivered across Europe' },
  { value: '2 GW+', label: 'Total installed capacity managed' },
  { value: '15+', label: 'Years of industry expertise' },
];
---

<!-- Stats section with a real aerial photo background -->
<section
  class="relative py-24 lg:py-32 overflow-hidden"
>
  <!-- Background photo with light overlay -->
  <div
    class="absolute inset-0 bg-cover bg-center"
    style="background-image: url('/images/site/stats-bg.jpg')"
  />
  <div
    class="absolute inset-0"
    style="background: linear-gradient(135deg, rgba(255,255,255,0.92) 0%, rgba(232,253,245,0.90) 50%, rgba(0,196,122,0.15) 100%)"
  />

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Label -->
    <div class="text-center mb-14 reveal">
      <span
        class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-4"
        style="background: rgba(0,196,122,0.15); color: var(--color-primary-dark)"
      >By The Numbers</span>
      <h2 class="text-4xl md:text-5xl font-800 leading-snug" style="color: var(--color-dark)">
        Renewable Energy Is<br /><span class="text-gradient">Gaining Momentum</span>
      </h2>
    </div>

    <!-- Stats grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
      {stats.map((stat, i) => (
        <div
          class="text-center p-8 rounded-2xl bg-white reveal card-hover"
          style={`border: 1px solid rgba(0,196,122,0.15); transition-delay: ${i * 100}ms; box-shadow: 0 8px 24px rgba(0,196,122,0.08)`}
        >
          <p
            class="text-4xl md:text-5xl font-800 mb-2 text-gradient"
            style="font-family: 'Urbanist', sans-serif"
          >{stat.value}</p>
          <p class="text-sm leading-snug" style="color: var(--color-muted)">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
