---
import { useTranslations } from '../i18n/ui';
import { defaultLang } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

export interface Props { lang?: Lang; }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const markets = [
  {
    title: t('markets.m1.title'),
    description: t('markets.m1.desc'),
    photo: '/images/site/residential-solar.jpg',
    items: [t('markets.m1.i1'), t('markets.m1.i2'), t('markets.m1.i3'), t('markets.m1.i4')],
  },
  {
    title: t('markets.m2.title'),
    description: t('markets.m2.desc'),
    photo: '/images/site/commercial-building.jpg',
    items: [t('markets.m2.i1'), t('markets.m2.i2'), t('markets.m2.i3'), t('markets.m2.i4')],
  },
  {
    title: t('markets.m3.title'),
    description: t('markets.m3.desc'),
    photo: '/images/site/municipal-city.jpg',
    items: [t('markets.m3.i1'), t('markets.m3.i2'), t('markets.m3.i3'), t('markets.m3.i4')],
  },
];
---

<section id="markets" class="py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <!-- Heading -->
    <div class="text-center mb-16 reveal">
      <span
        class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-4"
        style="background: rgba(249,168,0,0.12); color: var(--color-amber-dark)"
      >{t('markets.badge')}</span>
      <h2 class="text-4xl md:text-5xl font-800 mb-4 leading-snug" style="color: var(--color-dark)">
        {t('markets.title1')}<br /><span class="text-gradient">{t('markets.title2')}</span>
      </h2>
    </div>

    <!-- Market cards -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {markets.map((market, i) => (
        <div
          class="rounded-3xl bg-white card-hover reveal"
          style={`border: 1px solid rgba(249,168,0,0.12); transition-delay: ${i * 120}ms`}
        >
          <div class="relative h-52 overflow-hidden rounded-t-3xl">
            <img
              src={market.photo}
              alt={market.title}
              class="w-full h-full object-cover"
              loading="lazy"
            />
            <div
              class="absolute inset-0"
              style="background: linear-gradient(to bottom, rgba(255,255,255,0.1) 0%, rgba(10,43,30,0.45) 100%)"
            />
          </div>

          <div class="p-6">
            <h3
              class="text-2xl font-800 mb-3 leading-snug"
              style="font-family: 'Urbanist', sans-serif; color: var(--color-dark)"
            >{market.title}</h3>
            <p class="text-sm leading-relaxed mb-5" style="color: var(--color-muted)">{market.description}</p>
            <ul class="space-y-2">
              {market.items.map(item => (
                <li class="flex items-center gap-2.5 text-sm" style="color: var(--color-text)">
                  <span
                    class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0"
                    style="background: var(--color-primary-light)"
                  >
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="color: var(--color-primary)">
                      <path d="M5 13l4 4L19 7"/>
                    </svg>
                  </span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
