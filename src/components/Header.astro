---
export interface Props {
  base?: string;
}
const { base = '' } = Astro.props;

const navLinks = [
  { label: 'Home', href: `${base}/#home` },
  { label: 'Services', href: `${base}/#services` },
  { label: 'Why Us', href: `${base}/#why-us` },
  { label: 'Process', href: `${base}/#process` },
  { label: 'Markets', href: `${base}/#markets` },
  { label: 'Contact', href: `${base}/#contact` },
];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md transition-shadow duration-300"
  style="background: rgba(13,27,42,0.94)"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center justify-between h-18 py-3">

    <!-- Logo -->
    <a href={`${base}/#home`} class="flex items-center">
      <img
        src="/images/Renervision-Logo.png"
        alt="Renervision"
        class="h-10 w-auto"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="nav-link text-sm font-500 transition-colors"
          style="color: rgba(255,255,255,0.75)"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <a
      href={`${base}/#contact`}
      class="hidden md:inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-600 text-white transition-all hover:scale-105 hover:shadow-lg"
      style="background: var(--color-primary)"
    >
      Get Started
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>

    <!-- Mobile burger -->
    <button
      id="menu-btn"
      class="md:hidden p-2 rounded-lg"
      style="color: rgba(255,255,255,0.85)"
      aria-label="Toggle menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 12h18M3 6h18M3 18h18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden" style="background: #0D1B2A; border-top: 1px solid rgba(255,255,255,0.08)">
    <nav class="flex flex-col px-6 py-4 gap-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-sm font-500 py-1"
          style="color: rgba(255,255,255,0.75)"
          onclick="document.getElementById('mobile-menu').classList.remove('open')"
        >
          {link.label}
        </a>
      ))}
      <a
        href={`${base}/#contact`}
        class="mt-2 text-center px-5 py-2.5 rounded-full text-sm font-600 text-white"
        style="background: var(--color-primary)"
      >
        Get Started
      </a>
    </nav>
  </div>
</header>
