---
import { useTranslations } from '../i18n/ui';
import { languages, defaultLang } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

export interface Props {
  base?: string;
  lang?: Lang;
  currentPath?: string;
}
const { base = '', lang = defaultLang, currentPath = '' } = Astro.props;
const t = useTranslations(lang);
const prefix = lang === defaultLang ? '' : `/${lang}`;

const navLinks = [
  { label: t('nav.home'), href: `${prefix}/#home` },
  { label: t('nav.services'), href: `${prefix}/#services` },
  { label: t('nav.whyUs'), href: `${prefix}/#why-us` },
  { label: t('nav.process'), href: `${prefix}/#process` },
  { label: t('nav.markets'), href: `${prefix}/#markets` },
  { label: t('nav.contact'), href: `${prefix}/#contact` },
];

// Build language switcher paths
function langPath(targetLang: Lang): string {
  if (targetLang === defaultLang) return '/';
  return `/${targetLang}/`;
}
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md transition-shadow duration-300"
  style="background: rgba(13,27,42,0.94)"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center justify-between h-18 py-3">

    <!-- Logo -->
    <a href={`${prefix}/#home`} class="flex items-center">
      <img
        src="/images/Renervision-Logo.png"
        alt="Renervision"
        class="h-10 w-auto"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="nav-link text-sm font-500 transition-colors"
          style="color: rgba(255,255,255,0.75)"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right side: lang switcher + CTA -->
    <div class="hidden md:flex items-center gap-4">
      <!-- Language Switcher -->
      <div class="relative" id="lang-switcher">
        <button
          id="lang-btn"
          class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-500 transition-all hover:bg-white/10"
          style="color: rgba(255,255,255,0.8)"
          aria-label="Switch language"
        >
          <span>{languages[lang].flag}</span>
          <span class="hidden lg:inline">{languages[lang].label}</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </button>
        <div
          id="lang-dropdown"
          class="absolute right-0 top-full mt-2 py-2 rounded-xl shadow-2xl min-w-[160px] opacity-0 pointer-events-none transition-all duration-200 scale-95"
          style="background: #0D1B2A; border: 1px solid rgba(255,255,255,0.12)"
        >
          {Object.entries(languages).map(([code, { label, flag }]) => (
            <a
              href={langPath(code as Lang)}
              class={`flex items-center gap-2.5 px-4 py-2 text-sm transition-colors hover:bg-white/10 ${code === lang ? 'font-600' : ''}`}
              style={`color: ${code === lang ? '#F9A800' : 'rgba(255,255,255,0.7)'}`}
            >
              <span>{flag}</span>
              <span>{label}</span>
              {code === lang && (
                <svg class="ml-auto" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color: #F9A800">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <a
        href={`${prefix}/#contact`}
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-600 text-white transition-all hover:scale-105 hover:shadow-lg"
        style="background: var(--color-primary)"
      >
        {t('nav.getStarted')}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Mobile burger -->
    <button
      id="menu-btn"
      class="md:hidden p-2 rounded-lg"
      style="color: rgba(255,255,255,0.85)"
      aria-label="Toggle menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 12h18M3 6h18M3 18h18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden" style="background: #0D1B2A; border-top: 1px solid rgba(255,255,255,0.08)">
    <nav class="flex flex-col px-6 py-4 gap-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-sm font-500 py-1"
          style="color: rgba(255,255,255,0.75)"
          onclick="document.getElementById('mobile-menu').classList.remove('open')"
        >
          {link.label}
        </a>
      ))}

      <!-- Mobile language switcher -->
      <div class="flex flex-wrap gap-2 pt-2" style="border-top: 1px solid rgba(255,255,255,0.08)">
        {Object.entries(languages).map(([code, { label, flag }]) => (
          <a
            href={langPath(code as Lang)}
            class={`flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs transition-colors ${code === lang ? 'font-600' : ''}`}
            style={`background: ${code === lang ? 'rgba(249,168,0,0.15)' : 'rgba(255,255,255,0.06)'}; color: ${code === lang ? '#F9A800' : 'rgba(255,255,255,0.6)'}`}
          >
            <span>{flag}</span>
            <span>{label}</span>
          </a>
        ))}
      </div>

      <a
        href={`${prefix}/#contact`}
        class="mt-2 text-center px-5 py-2.5 rounded-full text-sm font-600 text-white"
        style="background: var(--color-primary)"
      >
        {t('nav.getStarted')}
      </a>
    </nav>
  </div>
</header>

<script>
  // Language dropdown toggle
  const langBtn = document.getElementById('lang-btn');
  const langDropdown = document.getElementById('lang-dropdown');
  if (langBtn && langDropdown) {
    langBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !langDropdown.classList.contains('pointer-events-none');
      if (isOpen) {
        langDropdown.classList.add('opacity-0', 'pointer-events-none', 'scale-95');
      } else {
        langDropdown.classList.remove('opacity-0', 'pointer-events-none', 'scale-95');
      }
    });
    document.addEventListener('click', () => {
      langDropdown.classList.add('opacity-0', 'pointer-events-none', 'scale-95');
    });
  }
</script>
