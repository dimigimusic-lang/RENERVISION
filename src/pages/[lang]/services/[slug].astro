---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { allServices } from '../../../data/services';
import { useTranslations } from '../../../i18n/ui';
import { getServiceText } from '../../../i18n/services';
import { langList, defaultLang } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/utils';

export function getStaticPaths() {
  const paths: { params: { lang: string; slug: string }; props: { service: typeof allServices[number]; lang: Lang } }[] = [];
  for (const lang of langList) {
    if (lang === defaultLang) continue;
    for (const s of allServices) {
      paths.push({
        params: { lang, slug: s.slug },
        props: { service: s, lang },
      });
    }
  }
  return paths;
}

const { service, lang } = Astro.props;
const t = useTranslations(lang);
const prefix = `/${lang}`;

// Overlay translated text if available
const translated = getServiceText(service.slug, lang);
const title = translated?.title ?? service.title;
const tagline = translated?.tagline ?? service.tagline;
const description = translated?.description ?? service.description;

const { heroImage, accent, accentLight, accentDark, howItWorks: enHowItWorks, benefits: enBenefits, chart } = service;

// Overlay translated howItWorks and benefits if available
const howItWorks = translated?.howItWorks
  ? enHowItWorks.map((step, i) => ({
      ...step,
      title: translated.howItWorks![i]?.title ?? step.title,
      description: translated.howItWorks![i]?.description ?? step.description,
    }))
  : enHowItWorks;

const benefits = translated?.benefits
  ? enBenefits.map((b, i) => ({
      ...b,
      title: translated.benefits![i]?.title ?? b.title,
      description: translated.benefits![i]?.description ?? b.description,
    }))
  : enBenefits;
---

<Layout title={`${title} — RENERVISION`} description={description}>
  <Header lang={lang} />
  <main>

    <!-- ── Hero ────────────────────────────────────────────────── -->
    <section class="relative min-h-[520px] flex items-end pb-16 pt-36" style="overflow-x: clip">
      <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImage}')`} />
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(13,27,42,0.68) 0%, rgba(13,27,42,0.82) 100%)" />

      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 w-full">
        <nav class="flex items-center gap-2 text-sm mb-6" style="color: rgba(255,255,255,0.55)">
          <a href={`${prefix}/`} class="hover:text-white transition-colors">{t('servicePage.breadHome')}</a>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
          <a href={`${prefix}/#services`} class="hover:text-white transition-colors">{t('servicePage.breadServices')}</a>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
          <span style="color: rgba(255,255,255,0.85)">{title}</span>
        </nav>

        <span
          class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-4"
          style={`background: rgba(255,255,255,0.12); color: white; border: 1px solid rgba(255,255,255,0.2)`}
        >{t('servicePage.badge')}</span>

        <h1 class="text-5xl md:text-6xl font-800 mb-4 leading-tight text-white">{title}</h1>
        <p class="text-xl md:text-2xl font-500 mb-8" style={`color: ${accent}`}>{tagline}</p>
        <p class="max-w-2xl text-lg leading-relaxed" style="color: rgba(255,255,255,0.8)">{description}</p>
      </div>
    </section>

    <!-- ── How It Works ───────────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="text-center mb-16 reveal">
          <span
            class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-4"
            style={`background: ${accentLight}; color: ${accentDark}`}
          >{t('servicePage.howItWorksBadge')}</span>
          <h2 class="text-4xl md:text-5xl font-800 mb-4 leading-snug" style="color: var(--color-dark)">
            {t('servicePage.howItWorksTitle1')}<br /><span class="text-gradient">{t('servicePage.howItWorksTitle2')}</span>
          </h2>
          <p class="max-w-xl mx-auto text-lg" style="color: var(--color-muted)">
            {t('servicePage.howItWorksSubtitle')}
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {howItWorks.map((step, i) => (
            <div
              class="flex gap-5 p-6 rounded-2xl bg-white reveal"
              style={`border: 1px solid rgba(13,27,42,0.07); transition-delay: ${i * 100}ms`}
            >
              <div class="flex-shrink-0">
                <div
                  class="w-14 h-14 rounded-2xl flex items-center justify-center text-white"
                  style={`background: ${accent}`}
                  set:html={step.icon}
                />
              </div>
              <div>
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-sm font-700 opacity-40" style="font-family: 'Urbanist', sans-serif; color: var(--color-dark)">{step.step}</span>
                  <h3 class="text-lg font-700" style="color: var(--color-dark)">{step.title}</h3>
                </div>
                <p class="text-sm leading-relaxed" style="color: var(--color-muted)">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Benefits ───────────────────────────────────────────── -->
    <section class="py-24 lg:py-32" style="background: var(--color-surface)">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="text-center mb-16 reveal">
          <span
            class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-4"
            style={`background: ${accentLight}; color: ${accentDark}`}
          >{t('servicePage.advantagesBadge')}</span>
          <h2 class="text-4xl md:text-5xl font-800 mb-4 leading-snug" style="color: var(--color-dark)">
            {t('servicePage.advantagesTitle1')}<br /><span class="text-gradient">{title}</span>
          </h2>
        </div>

        {(() => {
          const positions = ['50% 20%', '50% 50%', '50% 80%', '20% 50%', '80% 30%', '60% 70%'];
          return (
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {benefits.map((b, i) => (
                <div
                  class="rounded-2xl bg-white overflow-hidden reveal"
                  style={`border: 1px solid rgba(13,27,42,0.07); transition-delay: ${i * 80}ms`}
                >
                  <div class="relative h-36 overflow-hidden">
                    <img
                      src={b.image ?? heroImage}
                      alt={b.title}
                      class="w-full h-full object-cover"
                      style={`object-position: ${positions[i % positions.length]}`}
                      loading="lazy"
                    />
                    <div
                      class="absolute inset-0"
                      style={`background: linear-gradient(135deg, ${accent}55 0%, rgba(13,27,42,0.45) 100%)`}
                    />
                    <div
                      class="absolute bottom-3 left-4 w-9 h-9 rounded-xl flex items-center justify-center text-white shadow-lg"
                      style={`background: ${accent}`}
                      set:html={b.icon ?? `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`}
                    />
                  </div>
                  <div class="p-5">
                    <h3 class="font-700 mb-2" style="color: var(--color-dark)">{b.title}</h3>
                    <p class="text-sm leading-relaxed" style="color: var(--color-muted)">{b.description}</p>
                  </div>
                </div>
              ))}
            </div>
          );
        })()}
      </div>
    </section>

    <!-- ── Comparison Chart ───────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="max-w-5xl mx-auto px-6 lg:px-10">
        <div class="text-center mb-12 reveal">
          <span
            class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-4"
            style={`background: ${accentLight}; color: ${accentDark}`}
          >{t('servicePage.dataBadge')}</span>
          <h2 class="text-3xl md:text-4xl font-800 mb-3 leading-snug" style="color: var(--color-dark)">{chart.title}</h2>
          <p class="text-base" style="color: var(--color-muted)">{chart.subtitle}</p>
        </div>

        <div
          class="bg-white rounded-3xl p-8 lg:p-12 reveal"
          style="border: 1px solid rgba(13,27,42,0.08); box-shadow: 0 24px 64px rgba(13,27,42,0.06)"
        >
          <div class="space-y-5">
            {chart.bars.map(bar => {
              const pct = Math.max(0, (bar.value / bar.max) * 100);
              return (
                <div>
                  <div class="flex justify-between items-center mb-2">
                    <span class="text-sm font-600" style="color: var(--color-dark)">{bar.label}</span>
                    <span class="text-sm font-700" style={`color: ${bar.color}`}>{bar.value} {chart.unit}</span>
                  </div>
                  <div class="h-9 rounded-xl relative overflow-hidden" style="background: var(--color-surface)">
                    <div
                      class="h-full rounded-xl flex items-center justify-end pr-3 transition-all duration-700"
                      style={`width: ${pct}%; background: ${bar.color}; min-width: 8px`}
                    />
                  </div>
                </div>
              );
            })}
          </div>
          <p class="text-xs mt-6" style="color: var(--color-muted)">{t('servicePage.sources')}</p>
        </div>
      </div>
    </section>

    <!-- ── CTA ────────────────────────────────────────────────── -->
    <section
      class="py-24 lg:py-28 relative overflow-hidden"
      style={`background: var(--color-dark)`}
    >
      <div
        class="absolute inset-0 opacity-10"
        style={`background: radial-gradient(ellipse at 70% 50%, ${accent} 0%, transparent 60%)`}
      />
      <div class="relative z-10 max-w-3xl mx-auto px-6 lg:px-10 text-center">
        <span
          class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-6"
          style={`background: ${accentLight}; color: ${accentDark}`}
        >{t('servicePage.ctaBadge')}</span>
        <h2 class="text-4xl md:text-5xl font-800 mb-6 leading-snug text-white">
          {t('servicePage.ctaTitle1')}<br />{title}?
        </h2>
        <p class="text-lg mb-10" style="color: rgba(255,255,255,0.65)">
          {t('servicePage.ctaBody')}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={`${prefix}/#contact`}
            class="px-8 py-4 rounded-full text-sm font-600 text-white transition-all hover:scale-105 hover:shadow-lg"
            style={`background: ${accent}`}
          >
            {t('servicePage.ctaBtn1')}
          </a>
          <a
            href={`${prefix}/#services`}
            class="px-8 py-4 rounded-full text-sm font-600 transition-all hover:scale-105"
            style="background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.2)"
          >
            {t('servicePage.ctaBtn2')}
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer lang={lang} />
</Layout>
