---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Phase 03: Implementation — RENERVISION" description="Procurement, civil and electrical works, equipment installation, commissioning and grid connection.">
  <Header />
  <main style="padding-top: 80px">

    <!-- Hero -->
    <section style="background: var(--color-dark); color: white" class="py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <a href="/#process" class="inline-flex items-center gap-2 text-sm mb-8 opacity-60 hover:opacity-100 transition-opacity" style="color: white">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          Back to Process
        </a>
        <div class="flex items-center gap-4 mb-6">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-white flex-shrink-0" style="background: var(--color-blue)">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <span class="text-6xl font-800 opacity-10 select-none" style="font-family:'Urbanist',sans-serif">03</span>
        </div>
        <h1 class="text-5xl lg:text-6xl font-800 mb-5 leading-tight" style="font-family:'Urbanist',sans-serif">
          Phase 03:<br />
          <span style="background: linear-gradient(135deg,#4A7FD4,#E84415); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text">Implementation</span>
        </h1>
        <p class="text-xl max-w-2xl" style="color: rgba(255,255,255,0.65)">
          The construction phase turns approved plans into a functioning power plant — from ground-breaking and civil works through equipment installation, testing, and first export to the grid.
        </p>
      </div>
    </section>

    <!-- Overview cards -->
    <section class="py-16" style="background: var(--color-surface)">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          {[
            { label: 'Duration', value: '6–24 months', icon: '🏗' },
            { label: 'Key output', value: 'COD Certificate', icon: '⚡' },
            { label: 'Decision gate', value: 'Grid Synchronisation', icon: '🔌' },
            { label: 'Cost', value: '90–95% of CAPEX', icon: '💶' },
          ].map(item => (
            <div class="bg-white rounded-2xl p-5 text-center" style="border: 1px solid rgba(13,27,42,0.07)">
              <div class="text-2xl mb-2">{item.icon}</div>
              <p class="text-xs font-600 uppercase tracking-wider mb-1" style="color: var(--color-muted)">{item.label}</p>
              <p class="font-700" style="color: var(--color-dark)">{item.value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Main content -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-2 gap-16 items-start">

        <!-- Left: description + deliverables -->
        <div>
          <h2 class="text-3xl font-800 mb-6" style="color: var(--color-dark)">What happens in this phase?</h2>
          <div class="space-y-5 text-base leading-relaxed" style="color: var(--color-muted)">
            <p>Implementation is where capital is deployed. It begins with EPC (Engineering, Procurement and Construction) contract execution, followed by site mobilisation, civil foundations, internal roads, and cable trenching.</p>
            <p>Equipment — panels, turbines, transformers, switchgear — is procured under long-term supply agreements and delivered to site according to a detailed logistics plan. Installation crews work in parallel across zones to compress the schedule.</p>
            <p>The phase closes with pre-commissioning tests, load testing, grid synchronisation, and the Commercial Operation Date (COD) declaration, at which point revenue generation begins.</p>
          </div>

          <div class="mt-10">
            <h3 class="text-xl font-700 mb-4" style="color: var(--color-dark)">Key Deliverables</h3>
            <ul class="space-y-3">
              {[
                'EPC contract execution & contractor mobilisation',
                'Civil works: foundations, roads, fencing, cable routes',
                'Equipment delivery & acceptance testing',
                'Electrical installation & cabling',
                'HV substation construction & energisation',
                'SCADA & protection relay commissioning',
                'Pre-commissioning & performance tests',
                'Commercial Operation Date (COD) certificate',
              ].map(item => (
                <li class="flex items-start gap-3 text-sm" style="color: var(--color-text)">
                  <span class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background: var(--color-blue-light)">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="color: var(--color-blue-dark)"><path d="M5 13l4 4L19 7"/></svg>
                  </span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Right: Construction timeline -->
        <div>
          <h3 class="text-xl font-700 mb-6" style="color: var(--color-dark)">Construction Schedule (18-month EPC)</h3>
          <div class="bg-white rounded-2xl p-6" style="border: 1px solid rgba(13,27,42,0.07)">
            <div class="flex mb-3" style="padding-left: 150px">
              {['Q1','','Q2','','Q3','','Q4','','Q5','','Q6',''].map((q,i) => (
                <div class="flex-1 text-center text-xs font-600" style="color: var(--color-muted)">{q}</div>
              ))}
            </div>
            {[
              { task: 'Mobilisation', start: 0, span: 1, color: '#F9A800' },
              { task: 'Civil Works', start: 1, span: 4, color: '#E84415' },
              { task: 'Equipment Procurement', start: 0, span: 6, color: '#4A7FD4' },
              { task: 'Equipment Installation', start: 5, span: 4, color: '#E84415' },
              { task: 'Electrical & Cabling', start: 6, span: 4, color: '#4A7FD4' },
              { task: 'Substation Works', start: 7, span: 3, color: '#F9A800' },
              { task: 'Testing & Commissioning', start: 10, span: 2, color: '#E84415' },
            ].map(row => (
              <div class="flex items-center mb-2.5">
                <div class="text-xs font-500 pr-3 flex-shrink-0 text-right" style={`width: 150px; color: var(--color-text)`}>{row.task}</div>
                <div class="flex flex-1 gap-0.5">
                  {Array.from({length: 12}).map((_, i) => (
                    <div
                      class="flex-1 h-6 rounded"
                      style={`background: ${i >= row.start && i < row.start + row.span ? row.color : 'var(--color-surface)'}`}
                    />
                  ))}
                </div>
              </div>
            ))}
            <!-- COD marker -->
            <div class="mt-3 flex items-center gap-2 justify-end">
              <div class="w-3 h-3 rounded-full" style="background: #E84415"></div>
              <span class="text-xs font-600" style="color: var(--color-primary)">COD — Month 18</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quality & Safety milestones -->
    <section class="py-16" style="background: var(--color-surface)">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <h2 class="text-3xl font-800 mb-10 text-center" style="color: var(--color-dark)">Quality & Commissioning Gates</h2>
        <div class="relative">
          <!-- Vertical line -->
          <div class="absolute left-8 top-0 bottom-0 w-0.5 hidden lg:block" style="background: linear-gradient(to bottom, #E84415, #F9A800, #4A7FD4)"></div>
          <div class="space-y-6">
            {[
              { gate: 'G1', title: 'Site Readiness Review', desc: 'Verification of all permits, site access, safety plan, and contractor insurance before ground-breaking.', color: '#E84415' },
              { gate: 'G2', title: 'Foundation Acceptance', desc: 'Independent structural engineer sign-off on all foundations, cable ducts, and ground works before erection.', color: '#E84415' },
              { gate: 'G3', title: 'Equipment Factory Acceptance Test (FAT)', desc: 'Inverters, transformers, and switchgear tested at the manufacturer facility before shipping.', color: '#F9A800' },
              { gate: 'G4', title: 'Site Acceptance Test (SAT)', desc: 'All installed equipment tested on-site. String-level IV curve testing for PV, load bank testing for turbines.', color: '#F9A800' },
              { gate: 'G5', title: 'Grid Synchronisation', desc: 'DSO/TSO engineer present. Protection relay settings verified. First export of electricity to the national grid.', color: '#4A7FD4' },
              { gate: 'G6', title: 'Performance Test & COD', desc: 'Minimum 30-day performance test at guaranteed output level. COD certificate issued. Revenue period begins.', color: '#4A7FD4' },
            ].map((g, i) => (
              <div class="flex gap-6 items-start">
                <div class="w-16 h-16 rounded-2xl flex items-center justify-center font-800 text-white flex-shrink-0 text-sm relative z-10" style={`background: ${g.color}; font-family:'Urbanist',sans-serif`}>
                  {g.gate}
                </div>
                <div class="bg-white rounded-xl p-5 flex-1" style="border: 1px solid rgba(13,27,42,0.07)">
                  <h4 class="font-700 mb-1" style="color: var(--color-dark)">{g.title}</h4>
                  <p class="text-sm leading-relaxed" style="color: var(--color-muted)">{g.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Navigation -->
    <section class="py-12" style="background: var(--color-surface)">
      <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center justify-between">
        <a href="/process/planning" class="inline-flex items-center gap-2 text-sm font-600" style="color: var(--color-muted)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          Phase 02: Planning
        </a>
        <a href="/process/operation" class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-600 text-white" style="background: var(--color-primary)">
          Phase 04: Operation & Maintenance
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
