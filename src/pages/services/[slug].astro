---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
const allServices = [
  {
    slug: 'solar',
    title: 'Solar Energy',
    tagline: 'Harnessing the Power of the Sun',
    description: 'Photovoltaic technology converts sunlight directly into electricity — cleanly, silently, and at rapidly falling cost. RENERVISION designs and delivers solar installations from 5 kW rooftop systems to 100 MW utility farms across Europe.',
    heroImage: '/images/slideshow/solar-energy-panels.jpg',
    accent: '#F9A800',
    accentLight: '#FFF8E1',
    accentDark: '#D48B00',
    stats: [
      { value: '90%', label: 'Electricity bill reduction possible' },
      { value: '25+', label: 'Years operational lifespan' },
      { value: '0 g', label: 'CO₂ per kWh at operation' },
      { value: '5–7', label: 'Year average payback in EU' },
    ],
    howItWorks: [
      {
        step: '01',
        title: 'Photovoltaic Effect',
        description: 'Solar cells made of silicon semiconductor layers absorb photons from sunlight. This energy knocks electrons loose, creating a direct current (DC) flow between the positive and negative layers of each cell.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="5"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>`,
      },
      {
        step: '02',
        title: 'Inverter Conversion',
        description: 'A high-efficiency inverter converts DC electricity generated by the panels into AC electricity compatible with the grid and your appliances. Modern string and micro-inverters achieve conversion efficiencies above 98%.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
      },
      {
        step: '03',
        title: 'Grid Integration',
        description: 'Surplus energy is exported to the grid, earning feed-in tariffs or credits. Battery storage systems can store daytime generation for night-time use, maximising self-consumption and independence.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
      },
      {
        step: '04',
        title: 'Smart Monitoring',
        description: 'Real-time dashboards track production, consumption, and export at panel level. Predictive analytics detect under-performing strings before they cause significant losses, ensuring maximum yield year-round.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
      },
    ],
    benefits: [
      { title: 'Lowest Cost Energy',       image: '/images/slideshow/solar-energy-panels.jpg',                                                     icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`, description: 'Solar PV reached a global LCOE of ~$28/MWh in 2024 — cheaper than any other new-build power source. Operating costs are near zero as sunlight is free.' },
      { title: 'Scalable from kW to GW',   image: '/images/slideshow/aerial-view-of-part-of-windmill-turbine-in-countryside-green-energy.jpg',     icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`, description: 'Modular panel technology scales from a 5 kW home rooftop to 500 MW utility farms with no fundamental change in technology.' },
      { title: 'Long-life, Low-maintenance', image: '/images/site/engineer-tablet.jpg',                                                            icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, description: 'Quality panels carry 25-year performance warranties. No moving parts means minimal maintenance — typically just an annual inspection and panel cleaning.' },
      { title: 'Energy Independence',       image: '/images/slideshow/valvestino-dam-in-italy-hydroelectric-power-plant-.jpg',                     icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`, description: 'On-site generation dramatically reduces dependence on volatile grid electricity prices. Pair with storage for near-complete independence.' },
      { title: 'Carbon-free Operation',     image: '/images/slideshow/Geothermal_Power_Plants.png',                                                icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 8C8 10 5.9 16.17 3.82 19.11c-.98 1.39-.63 2.89.5 2.89H19.5c1.13 0 1.48-1.5.5-2.89C17.9 16.17 16 12 16 8"/><path d="M12 2c1 2.5.5 4-1 6.5"/></svg>`, description: 'Zero direct emissions during operation. A typical 10 kW residential system offsets ~6 tonnes of CO₂ per year — equivalent to planting 280 trees annually.' },
      { title: 'Revenue Generation',        image: '/images/slideshow/wte_plant.png',                                                              icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`, description: 'Export tariffs, PPAs and EU incentive schemes allow solar assets to generate consistent, contracted revenue for 20+ years.' },
    ],
    chart: {
      title: 'Levelised Cost of Energy (LCOE)',
      subtitle: 'USD per MWh — global new-build average, 2024 (IRENA data)',
      bars: [
        { label: 'Solar PV', value: 28, max: 170, color: '#F9A800' },
        { label: 'Onshore Wind', value: 33, max: 170, color: '#4A7FD4' },
        { label: 'Geothermal', value: 48, max: 170, color: '#E84415' },
        { label: 'Hydroelectric', value: 52, max: 170, color: '#2E5FAA' },
        { label: 'Natural Gas', value: 65, max: 170, color: '#6B7A8D' },
        { label: 'Nuclear', value: 155, max: 170, color: '#9CA3AF' },
      ],
      unit: '$/MWh',
    },
  },

  {
    slug: 'wind',
    title: 'Wind Turbines',
    tagline: 'Capturing the Energy of Moving Air',
    description: 'Wind energy is the world\'s fastest-growing electricity source. RENERVISION delivers complete wind farm development — from resource assessment and permitting through to construction, grid connection and long-term operation.',
    heroImage: '/images/slideshow/aerial-view-of-part-of-windmill-turbine-in-countryside-green-energy.jpg',
    accent: '#4A7FD4',
    accentLight: '#EEF3FB',
    accentDark: '#2E5FAA',
    stats: [
      { value: '35–50%', label: 'Capacity factor (onshore/offshore)' },
      { value: '20–25', label: 'Years turbine design lifetime' },
      { value: '98%', label: 'Material recyclability of turbines' },
      { value: '6 mo', label: 'Energy payback period for turbine' },
    ],
    howItWorks: [
      {
        step: '01',
        title: 'Aerodynamic Lift',
        description: 'Wind turbine blades are precisely shaped aerofoils. As wind passes over them, a pressure difference is created that generates aerodynamic lift, causing the rotor to turn. Modern 3-blade designs maximise efficiency while minimising fatigue loads.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v20M8 6l4-4 4 4"/><circle cx="12" cy="12" r="2"/><path d="M4 12h16"/></svg>`,
      },
      {
        step: '02',
        title: 'Mechanical Transmission',
        description: 'The rotor hub turns a main shaft. Gearbox-equipped turbines step up the low rotational speed (~15 RPM) to ~1,500 RPM for the generator. Direct-drive turbines eliminate the gearbox entirely using permanent-magnet generators, improving reliability.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93l-1.41 1.41M6.34 17.66l-1.41 1.41M2 12h2M20 12h2M6.34 6.34L4.93 4.93M17.66 17.66l1.41 1.41M12 2v2M12 20v2"/></svg>`,
      },
      {
        step: '03',
        title: 'Power Generation',
        description: 'The generator converts rotational energy into 3-phase AC electricity. Power electronics and transformers condition the output to match the grid frequency and voltage. Turbine output is continuously optimised by yaw and pitch control systems.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
      },
      {
        step: '04',
        title: 'Grid Connection & SCADA',
        description: 'An onsite substation collects output from all turbines and steps voltage up for transmission. SCADA systems provide 24/7 remote monitoring, fault detection and performance reporting across the entire fleet.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
      },
    ],
    benefits: [
      { title: 'No Fuel Costs',           image: '/images/slideshow/aerial-view-of-part-of-windmill-turbine-in-countryside-green-energy.jpg', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`, description: 'Once built, a wind turbine\'s primary energy source — wind — is free. This makes operating costs predictably low and protects revenue from fuel price volatility.' },
      { title: 'High Capacity Factors',   image: '/images/slideshow/solar-energy-panels.jpg',                                                 icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`, description: 'Offshore wind sites routinely achieve capacity factors of 45–55%, far exceeding solar PV in northern European latitudes. Premium onshore sites reach 38–42%.' },
      { title: 'Small Land Footprint',    image: '/images/slideshow/valvestino-dam-in-italy-hydroelectric-power-plant-.jpg',                  icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`, description: 'A wind farm\'s actual surface occupation (turbine bases, roads) is only 1–2% of the total area. The land between turbines continues normal agricultural use.' },
      { title: 'Fast Construction',       image: '/images/site/engineer-tablet.jpg',                                                          icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`, description: 'A 50 MW onshore wind farm can be fully operational within 12–18 months of permit award — one of the fastest routes to new generation capacity.' },
      { title: 'Long Asset Life',         image: '/images/slideshow/Geothermal_Power_Plants.png',                                             icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, description: 'Modern turbines are designed for 25-year service lives. Repowering — replacing ageing rotors with larger, more efficient models on existing foundations — extends viable life further.' },
      { title: 'Complementary to Solar',  image: '/images/slideshow/wte_plant.png',                                                           icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="5"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3"/></svg>`, description: 'Wind and solar generation profiles are naturally complementary: wind tends to peak in winter mornings and evenings when solar is low, making a hybrid portfolio highly consistent.' },
    ],
    chart: {
      title: 'Capacity Factor by Technology',
      subtitle: 'Annual average capacity factor (%) — European conditions',
      bars: [
        { label: 'Offshore Wind', value: 50, max: 100, color: '#2E5FAA' },
        { label: 'Geothermal', value: 90, max: 100, color: '#E84415' },
        { label: 'Nuclear', value: 88, max: 100, color: '#9CA3AF' },
        { label: 'Onshore Wind', value: 36, max: 100, color: '#4A7FD4' },
        { label: 'Hydroelectric', value: 48, max: 100, color: '#06B6D4' },
        { label: 'Solar PV', value: 18, max: 100, color: '#F9A800' },
      ],
      unit: '%',
    },
  },

  {
    slug: 'hydro',
    title: 'Hydroelectric',
    tagline: 'The World\'s Most Reliable Renewable Power',
    description: 'Hydroelectric power converts the energy of flowing water into electricity with unmatched efficiency. From run-of-river installations to large dam projects, RENERVISION delivers hydropower solutions that provide dispatchable, baseload renewable electricity.',
    heroImage: '/images/slideshow/valvestino-dam-in-italy-hydroelectric-power-plant-.jpg',
    accent: '#4A7FD4',
    accentLight: '#EEF3FB',
    accentDark: '#2E5FAA',
    stats: [
      { value: '90%', label: 'Conversion efficiency (best of all sources)' },
      { value: '50–100', label: 'Years design life for civil works' },
      { value: '24/7', label: 'Dispatchable baseload power' },
      { value: '4 g', label: 'CO₂-equivalent per kWh lifecycle' },
    ],
    howItWorks: [
      {
        step: '01',
        title: 'Water Head & Flow',
        description: 'Hydropower exploits the potential energy of water at elevation. The available power is proportional to both the flow rate (m³/s) and the head — the vertical height difference between the intake and the turbine. Higher head allows smaller turbines for the same output.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M2 12h20M12 2a15.3 15.3 0 000 20"/></svg>`,
      },
      {
        step: '02',
        title: 'Turbine Types',
        description: 'Pelton turbines suit high-head (>200 m) low-flow sites; Francis turbines are versatile across medium head (20–700 m); Kaplan turbines handle low-head, high-flow run-of-river sites. Each converts water kinetic and pressure energy into shaft rotation with 88–93% efficiency.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>`,
      },
      {
        step: '03',
        title: 'Generator & Transformer',
        description: 'The turbine drives a synchronous generator producing 3-phase AC power. Large hydro generators achieve efficiencies above 97%. Output is stepped up by a transformer to transmission voltage for grid export.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
      },
      {
        step: '04',
        title: 'Dispatch & Storage',
        description: 'Unlike solar or wind, hydropower output can be precisely controlled by adjusting gate openings. Pumped-storage hydro goes further — pumping water uphill during low-demand periods and releasing it during peaks, acting as a giant rechargeable battery.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
      },
    ],
    benefits: [
      { title: 'Highest Efficiency',       image: '/images/slideshow/valvestino-dam-in-italy-hydroelectric-power-plant-.jpg',                 icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`, description: 'Hydroelectric turbines convert 88–93% of available water energy to electricity — the highest efficiency of any commercial power generation technology, more than double coal or gas plants.' },
      { title: 'Fully Dispatchable',       image: '/images/slideshow/aerial-view-of-part-of-windmill-turbine-in-countryside-green-energy.jpg', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18.36 6.64a9 9 0 11-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>`, description: 'Unlike wind and solar, hydro output can be ramped up or down in seconds. This makes it invaluable for grid balancing and peak demand management.' },
      { title: 'Century-long Asset Life',  image: '/images/slideshow/solar-energy-panels.jpg',                                               icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`, description: 'The concrete civil works of a hydro dam routinely last 100+ years. Many European hydro plants built in the 1920s are still generating power today after turbine upgrades.' },
      { title: 'Minimal Operating Costs',  image: '/images/site/engineer-tablet.jpg',                                                        icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`, description: 'Once built, a run-of-river plant has extremely low marginal costs. No fuel, minimal maintenance. Revenue per MWh is among the most predictable of any technology.' },
      { title: 'Grid Stability Services',  image: '/images/slideshow/Geothermal_Power_Plants.png',                                           icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`, description: 'Hydro plants provide inertia, reactive power support and fast frequency response that are essential for stable grid operation — services that command premium payments as grids decarbonise.' },
      { title: 'Multiple Water Benefits',  image: '/images/slideshow/wte_plant.png',                                                         icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>`, description: 'Hydro reservoirs provide flood control, irrigation supply, drinking water storage and recreational amenity — community benefits that extend well beyond power generation.' },
    ],
    chart: {
      title: 'Power Conversion Efficiency by Technology',
      subtitle: 'Percentage of primary energy converted to electricity',
      bars: [
        { label: 'Hydroelectric', value: 92, max: 100, color: '#4A7FD4' },
        { label: 'Wind Turbine', value: 45, max: 100, color: '#2E5FAA' },
        { label: 'Combined Cycle Gas', value: 60, max: 100, color: '#6B7A8D' },
        { label: 'Nuclear', value: 33, max: 100, color: '#9CA3AF' },
        { label: 'Coal', value: 36, max: 100, color: '#374151' },
        { label: 'Solar PV', value: 22, max: 100, color: '#F9A800' },
      ],
      unit: '%',
    },
  },

  {
    slug: 'geothermal',
    title: 'Geothermal Energy',
    tagline: 'Baseload Power from the Earth\'s Core',
    description: 'Geothermal energy taps the Earth\'s internal heat — a virtually inexhaustible resource available 24 hours a day, 365 days a year. RENERVISION develops geothermal projects for both electricity generation and direct heating applications across geologically active European regions.',
    heroImage: '/images/slideshow/Geothermal_Power_Plants.png',
    accent: '#E84415',
    accentLight: '#FEF0EC',
    accentDark: '#C43610',
    stats: [
      { value: '90%+', label: 'Capacity factor (24/7 baseload)' },
      { value: '30+', label: 'Years plant operational life' },
      { value: '38 g', label: 'CO₂-eq per kWh (EGS, lifecycle)' },
      { value: '0.1%', label: 'Land footprint vs. equivalent solar' },
    ],
    howItWorks: [
      {
        step: '01',
        title: 'Resource Assessment',
        description: 'Geothermal potential is mapped via seismic surveys, gravity studies and temperature gradient analysis. High-enthalpy resources (>150°C) suitable for electricity generation occur in volcanically active zones; low-enthalpy resources (30–150°C) for district heating are found across much of Europe.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
      },
      {
        step: '02',
        title: 'Well Drilling',
        description: 'Production wells are drilled to depths of 1–5 km to reach the geothermal reservoir. Directional drilling allows multiple wells from a single pad, minimising surface disturbance. Injection wells return cooled water to the reservoir, ensuring sustainability.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22V12M12 12C12 6.477 7.523 2 2 2M12 12c0-5.523 4.477-10 10-10"/><path d="M3 21s2-3 4-3 3 3 5 3 3-3 5-3 4 3 4 3"/></svg>`,
      },
      {
        step: '03',
        title: 'Power Conversion',
        description: 'High-temperature steam (dry steam or flash plants) drives turbines directly. For lower temperatures (70–150°C), binary cycle plants use a working fluid with a lower boiling point (e.g. isopentane) in a closed secondary loop — emitting no steam to atmosphere.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
      },
      {
        step: '04',
        title: 'Direct Heat Applications',
        description: 'Geothermal fluids at 30–90°C are ideal for district heating networks, greenhouse agriculture, aquaculture, and industrial processes. Cascaded systems use the same well fluid for electricity generation, space heating, and process heat in sequence, maximising efficiency.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 8C8 10 5.9 16.17 3.82 19.11c-.98 1.39-.63 2.89.5 2.89H19.5c1.13 0 1.48-1.5.5-2.89C17.9 16.17 16 12 16 8"/><path d="M12 2c1 2.5.5 4-1 6.5"/></svg>`,
      },
    ],
    benefits: [
      { title: 'Continuous Baseload Power', image: '/images/slideshow/Geothermal_Power_Plants.png',                                            icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`, description: 'Geothermal plants run at 90–95% capacity factors — more reliably than any other renewable. Unlike solar and wind, output is unaffected by weather, season or time of day.' },
      { title: 'Tiny Land Footprint',       image: '/images/slideshow/aerial-view-of-part-of-windmill-turbine-in-countryside-green-energy.jpg', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`, description: 'A 100 MW geothermal plant occupies roughly 1 km² including all wells and infrastructure — about 1/25th the land required by an equivalent solar farm.' },
      { title: 'Very Low Emissions',        image: '/images/slideshow/valvestino-dam-in-italy-hydroelectric-power-plant-.jpg',                  icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 8C8 10 5.9 16.17 3.82 19.11c-.98 1.39-.63 2.89.5 2.89H19.5c1.13 0 1.48-1.5.5-2.89C17.9 16.17 16 12 16 8"/><path d="M12 2c1 2.5.5 4-1 6.5"/></svg>`, description: 'Modern binary-cycle plants are closed-loop systems with near-zero atmospheric emissions. Lifecycle CO₂-equivalent is 15–55 g/kWh — among the cleanest power sources available.' },
      { title: 'Stable, Predictable Costs', image: '/images/site/engineer-tablet.jpg',                                                          icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`, description: 'After well drilling (the main capital cost), geothermal generation has very low and predictable operational costs, making it an excellent baseload complement to variable renewables.' },
      { title: 'Dual Revenue Streams',      image: '/images/slideshow/solar-energy-panels.jpg',                                                icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`, description: 'Where heat markets exist alongside electricity markets, cascaded geothermal systems generate revenue from both simultaneously, improving project economics significantly.' },
      { title: 'Local Energy Security',     image: '/images/slideshow/wte_plant.png',                                                          icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, description: 'Geothermal resources are indigenous — they cannot be disrupted by supply chain issues, geopolitical events or international commodity price movements.' },
    ],
    chart: {
      title: 'Annual Capacity Factor by Technology',
      subtitle: 'Percentage of time at full rated output, European averages',
      bars: [
        { label: 'Geothermal', value: 92, max: 100, color: '#E84415' },
        { label: 'Nuclear', value: 88, max: 100, color: '#9CA3AF' },
        { label: 'Waste-to-Energy', value: 82, max: 100, color: '#C43610' },
        { label: 'Offshore Wind', value: 50, max: 100, color: '#2E5FAA' },
        { label: 'Onshore Wind', value: 36, max: 100, color: '#4A7FD4' },
        { label: 'Solar PV', value: 18, max: 100, color: '#F9A800' },
      ],
      unit: '%',
    },
  },

  {
    slug: 'waste-to-energy',
    title: 'Waste-to-Energy',
    tagline: 'Turning Society\'s Waste into Clean Power',
    description: 'Waste-to-Energy (WtE) technology combusts municipal and industrial solid waste in highly controlled conditions to recover electricity and heat — simultaneously solving a waste management challenge and generating reliable baseload power. RENERVISION delivers complete WtE plant design, permitting and operation services.',
    heroImage: '/images/slideshow/wte_plant.png',
    accent: '#E84415',
    accentLight: '#FEF0EC',
    accentDark: '#C43610',
    stats: [
      { value: '90%', label: 'Volume reduction of input waste' },
      { value: '80%', label: 'Bottom ash recycled as aggregate' },
      { value: '2–3', label: 'MWh electricity per tonne of MSW' },
      { value: '99.99%', label: 'Dioxin/furan removal efficiency' },
    ],
    howItWorks: [
      {
        step: '01',
        title: 'Waste Reception & Pre-treatment',
        description: 'Incoming municipal solid waste (MSW) is delivered by collection vehicles to a tipping hall under negative air pressure, preventing odours escaping. A crane homogenises the waste pit content before feeding to the combustion grate, ensuring stable calorific value and steady combustion.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg>`,
      },
      {
        step: '02',
        title: 'Controlled Combustion',
        description: 'Waste burns on a moving grate at 850–1,000°C. EU Industrial Emissions Directive requires at least 2 seconds residence time above 850°C to destroy organic pollutants. Auxiliary burners maintain temperature during low-calorific-value periods. Bottom ash is extracted, cooled and sorted for metal recovery and aggregate use.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 8C8 10 5.9 16.17 3.82 19.11c-.98 1.39-.63 2.89.5 2.89H19.5c1.13 0 1.48-1.5.5-2.89C17.9 16.17 16 12 16 8M12 2c1 2.5.5 4-1 6.5"/></svg>`,
      },
      {
        step: '03',
        title: 'Energy Recovery',
        description: 'Hot combustion gases (850–1,000°C) pass through a boiler, generating high-pressure steam. The steam drives a turbine-generator producing electricity. In combined heat and power (CHP) mode, remaining low-pressure steam is extracted for district heating networks, achieving total efficiencies of 70–85%.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
      },
      {
        step: '04',
        title: 'Flue Gas Cleaning',
        description: 'A multi-stage cleaning system removes pollutants: electrostatic precipitators capture particulates; dry or wet scrubbers remove acid gases (HCl, SO₂); activated carbon injection adsorbs heavy metals and dioxins; SCR catalysts reduce NOx to near-zero. Modern WtE flue gas is often cleaner than urban traffic air.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12a9 9 0 1018 0 9 9 0 00-18 0z"/><path d="M9 12l2 2 4-4"/></svg>`,
      },
    ],
    benefits: [
      { title: 'Dual Revenue Model',          image: '/images/slideshow/wte_plant.png',                                                              icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`, description: 'WtE plants earn gate fees from waste authorities for accepting waste AND sell electricity and heat. This dual revenue stream makes the economics robust and independent of energy price volatility.' },
      { title: 'Baseload Reliability',         image: '/images/slideshow/Geothermal_Power_Plants.png',                                               icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`, description: 'WtE plants operate at 80–85% annual capacity factors, providing consistent, schedulable power that complements variable renewables on the grid.' },
      { title: 'Circular Economy Champion',    image: '/images/slideshow/aerial-view-of-part-of-windmill-turbine-in-countryside-green-energy.jpg',   icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/></svg>`, description: 'WtE recovers energy, metals and aggregate from waste that would otherwise be landfilled. Bottom ash metal sorting recovers 15–20 kg of metals per tonne of MSW processed.' },
      { title: 'Landfill Diversion',           image: '/images/slideshow/valvestino-dam-in-italy-hydroelectric-power-plant-.jpg',                    icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg>`, description: 'Landfill produces methane — a greenhouse gas 25× more potent than CO₂. Each tonne diverted from landfill to WtE prevents landfill gas emissions and permanent soil contamination.' },
      { title: 'EU-compliant Emissions',       image: '/images/site/engineer-tablet.jpg',                                                            icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`, description: 'Modern WtE plants easily meet the stringent EU Industrial Emissions Directive limits for all regulated pollutants. Continuous Emissions Monitoring Systems (CEMS) provide full transparency.' },
      { title: 'District Heating Integration', image: '/images/slideshow/solar-energy-panels.jpg',                                                   icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`, description: 'In CHP configuration, WtE plants become backbone assets of district heating networks — providing affordable, low-carbon heat to residential and commercial customers year-round.' },
    ],
    chart: {
      title: 'Waste Hierarchy: CO₂ Impact Comparison',
      subtitle: 'Relative CO₂-equivalent impact per tonne of residual waste treated',
      bars: [
        { label: 'Landfill (no gas capture)', value: 100, max: 120, color: '#374151' },
        { label: 'Landfill (with gas capture)', value: 65, max: 120, color: '#6B7A8D' },
        { label: 'Waste-to-Energy (power only)', value: 22, max: 120, color: '#E84415' },
        { label: 'WtE + District Heating (CHP)', value: 8, max: 120, color: '#C43610' },
        { label: 'Mechanical recycling', value: -5, max: 120, color: '#4A7FD4' },
      ],
      unit: 'CO₂-eq index',
    },
  },

  {
    slug: 'consulting',
    title: 'Energy Consulting',
    tagline: 'Expert Guidance from Concept to Financial Close',
    description: 'Successful renewable energy projects are built on rigorous analysis and deep regulatory knowledge. RENERVISION\'s consulting practice provides independent feasibility studies, grid connection advisory, permitting support and financial modelling to investors, developers and municipalities across Europe.',
    heroImage: '/images/site/energy-consulting.jpg',
    accent: '#F9A800',
    accentLight: '#FFF8E1',
    accentDark: '#D48B00',
    stats: [
      { value: '200+', label: 'Projects assessed across Europe' },
      { value: '15+', label: 'Years average team experience' },
      { value: '94%', label: 'Permit success rate for supported projects' },
      { value: '18%', label: 'Average IRR improvement vs. unadvised' },
    ],
    howItWorks: [
      {
        step: '01',
        title: 'Feasibility & Resource Study',
        description: 'We begin with a rigorous resource assessment — solar irradiation, wind speed distribution, hydrological flow data or geothermal gradient — combined with a high-level financial model to determine whether a site has viable project economics before significant capital is committed.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
      },
      {
        step: '02',
        title: 'Grid Connection & Technical Design',
        description: 'We conduct load flow studies and short-circuit analyses to determine the optimal grid connection point and voltage level. Preliminary single-line diagrams, equipment specifications and connection cost estimates allow lenders and investors to understand technical risks early.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
      },
      {
        step: '03',
        title: 'Permitting & Regulatory Strategy',
        description: 'Our permitting specialists map every required consent — environmental impact assessment, building permits, grid connection agreement, operating licences — across the relevant national and EU regulatory frameworks. We prepare application packages, manage consultations and represent clients in regulatory proceedings.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>`,
      },
      {
        step: '04',
        title: 'Financial Modelling & Investment Advisory',
        description: 'Detailed project finance models cover capital structure, debt service, revenue under various tariff scenarios, sensitivity analysis and investor returns (IRR, NPV, DSCR). We support debt financing, equity raise processes and PPA negotiations with offtakers.',
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`,
      },
    ],
    benefits: [
      { title: 'Risk Reduction',            image: '/images/site/engineer-tablet.jpg',                                                               icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, description: 'Expert feasibility analysis identifies fatal flaws before significant capital is spent — saving developers from expensive mistakes in site selection, grid connection or regulatory strategy.' },
      { title: 'Faster Permitting',         image: '/images/slideshow/solar-energy-panels.jpg',                                                      icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`, description: 'Projects supported by experienced consultants move through regulatory processes faster. Our 94% permit success rate reflects deep knowledge of what works in each EU jurisdiction.' },
      { title: 'Better Financing Terms',    image: '/images/slideshow/aerial-view-of-part-of-windmill-turbine-in-countryside-green-energy.jpg',      icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`, description: 'Lenders and equity investors pay a premium for well-prepared projects. Thorough technical and financial documentation reduces perceived risk, lowering cost of capital and improving deal terms.' },
      { title: 'Optimised Design',          image: '/images/slideshow/valvestino-dam-in-italy-hydroelectric-power-plant-.jpg',                       icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`, description: 'Independent engineering review often identifies significant yield improvements (2–8%) or cost savings through revised layout, equipment selection or connection strategy.' },
      { title: 'Technology-agnostic Advice', image: '/images/slideshow/Geothermal_Power_Plants.png',                                                 icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`, description: 'We have no equipment sales interests. Our advice is focused entirely on project success — meaning we select the right technology for each site rather than promoting a preferred supplier.' },
      { title: 'Ongoing Advisory',          image: '/images/slideshow/wte_plant.png',                                                                icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`, description: 'Our relationship continues post-construction: annual performance audits, refinancing advisory, change-of-law analysis and O&M benchmarking keep your asset performing at its best throughout its life.' },
    ],
    chart: {
      title: 'Impact of Expert Consulting on Project Outcomes',
      subtitle: 'Average improvement vs. unadvised projects (RENERVISION portfolio, 2019–2024)',
      bars: [
        { label: 'Energy yield improvement', value: 7, max: 30, color: '#F9A800' },
        { label: 'Permitting time reduction', value: 28, max: 30, color: '#D48B00' },
        { label: 'CapEx reduction', value: 9, max: 30, color: '#4A7FD4' },
        { label: 'IRR improvement', value: 18, max: 30, color: '#E84415' },
        { label: 'Financing cost reduction', value: 12, max: 30, color: '#2E5FAA' },
      ],
      unit: '%',
    },
  },
];
  return allServices.map(s => ({
    params: { slug: s.slug },
    props: { service: s },
  }));
}

const { service } = Astro.props;
const { title, tagline, description, heroImage, accent, accentLight, accentDark, stats, howItWorks, benefits, chart } = service;
---

<Layout title={`${title} — RENERVISION`} description={description}>
  <Header />
  <main>

    <!-- ── Hero ────────────────────────────────────────────────── -->
    <section class="relative min-h-[520px] flex items-end pb-16 pt-36" style="overflow-x: clip">
      <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${heroImage}')`} />
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(13,27,42,0.68) 0%, rgba(13,27,42,0.82) 100%)" />

      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 w-full">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm mb-6" style="color: rgba(255,255,255,0.55)">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
          <a href="/#services" class="hover:text-white transition-colors">Services</a>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
          <span style="color: rgba(255,255,255,0.85)">{title}</span>
        </nav>

        <span
          class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-4"
          style={`background: rgba(255,255,255,0.12); color: white; border: 1px solid rgba(255,255,255,0.2)`}
        >Renewable Energy</span>

        <h1 class="text-5xl md:text-6xl font-800 mb-4 leading-tight text-white">{title}</h1>
        <p class="text-xl md:text-2xl font-500 mb-8" style={`color: ${accent}`}>{tagline}</p>
        <p class="max-w-2xl text-lg leading-relaxed" style="color: rgba(255,255,255,0.8)">{description}</p>
      </div>
    </section>

    <!-- ── Key Stats ──────────────────────────────────────────── -->
    <section class="py-14" style={`background: ${accentLight}`}>
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
          {stats.map(stat => (
            <div class="text-center">
              <div class="text-3xl md:text-4xl font-800 mb-1" style={`color: ${accentDark}; font-family: 'Urbanist', sans-serif`}>{stat.value}</div>
              <div class="text-sm leading-snug" style="color: var(--color-muted)">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── How It Works ───────────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="text-center mb-16 reveal">
          <span
            class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-4"
            style={`background: ${accentLight}; color: ${accentDark}`}
          >How It Works</span>
          <h2 class="text-4xl md:text-5xl font-800 mb-4 leading-snug" style="color: var(--color-dark)">
            The Technology<br /><span class="text-gradient">Behind the Power</span>
          </h2>
          <p class="max-w-xl mx-auto text-lg" style="color: var(--color-muted)">
            A step-by-step look at how {title.toLowerCase()} technology converts a natural resource into clean electricity.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {howItWorks.map((step, i) => (
            <div
              class="flex gap-5 p-6 rounded-2xl bg-white reveal"
              style={`border: 1px solid rgba(13,27,42,0.07); transition-delay: ${i * 100}ms`}
            >
              <div class="flex-shrink-0">
                <div
                  class="w-14 h-14 rounded-2xl flex items-center justify-center text-white"
                  style={`background: ${accent}`}
                  set:html={step.icon}
                />
              </div>
              <div>
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-sm font-700 opacity-40" style="font-family: 'Urbanist', sans-serif; color: var(--color-dark)">{step.step}</span>
                  <h3 class="text-lg font-700" style="color: var(--color-dark)">{step.title}</h3>
                </div>
                <p class="text-sm leading-relaxed" style="color: var(--color-muted)">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Benefits ───────────────────────────────────────────── -->
    <section class="py-24 lg:py-32" style="background: var(--color-surface)">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="text-center mb-16 reveal">
          <span
            class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-4"
            style={`background: ${accentLight}; color: ${accentDark}`}
          >Advantages</span>
          <h2 class="text-4xl md:text-5xl font-800 mb-4 leading-snug" style="color: var(--color-dark)">
            Why Choose<br /><span class="text-gradient">{title}</span>
          </h2>
        </div>

        {(() => {
          const positions = ['50% 20%', '50% 50%', '50% 80%', '20% 50%', '80% 30%', '60% 70%'];
          return (
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {benefits.map((b, i) => (
                <div
                  class="rounded-2xl bg-white overflow-hidden reveal"
                  style={`border: 1px solid rgba(13,27,42,0.07); transition-delay: ${i * 80}ms`}
                >
                  <!-- Photo header -->
                  <div class="relative h-36 overflow-hidden">
                    <img
                      src={b.image ?? heroImage}
                      alt={b.title}
                      class="w-full h-full object-cover"
                      style={`object-position: ${positions[i % positions.length]}`}
                      loading="lazy"
                    />
                    <div
                      class="absolute inset-0"
                      style={`background: linear-gradient(135deg, ${accent}55 0%, rgba(13,27,42,0.45) 100%)`}
                    />
                    <div
                      class="absolute bottom-3 left-4 w-9 h-9 rounded-xl flex items-center justify-center text-white shadow-lg"
                      style={`background: ${accent}`}
                      set:html={b.icon ?? `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`}
                    />
                  </div>
                  <!-- Content -->
                  <div class="p-5">
                    <h3 class="font-700 mb-2" style="color: var(--color-dark)">{b.title}</h3>
                    <p class="text-sm leading-relaxed" style="color: var(--color-muted)">{b.description}</p>
                  </div>
                </div>
              ))}
            </div>
          );
        })()}
      </div>
    </section>

    <!-- ── Comparison Chart ───────────────────────────────────── -->
    <section class="py-24 lg:py-32">
      <div class="max-w-5xl mx-auto px-6 lg:px-10">
        <div class="text-center mb-12 reveal">
          <span
            class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-4"
            style={`background: ${accentLight}; color: ${accentDark}`}
          >Data & Comparison</span>
          <h2 class="text-3xl md:text-4xl font-800 mb-3 leading-snug" style="color: var(--color-dark)">{chart.title}</h2>
          <p class="text-base" style="color: var(--color-muted)">{chart.subtitle}</p>
        </div>

        <div
          class="bg-white rounded-3xl p-8 lg:p-12 reveal"
          style="border: 1px solid rgba(13,27,42,0.08); box-shadow: 0 24px 64px rgba(13,27,42,0.06)"
        >
          <div class="space-y-5">
            {chart.bars.map(bar => {
              const pct = Math.max(0, (bar.value / bar.max) * 100);
              return (
                <div>
                  <div class="flex justify-between items-center mb-2">
                    <span class="text-sm font-600" style="color: var(--color-dark)">{bar.label}</span>
                    <span class="text-sm font-700" style={`color: ${bar.color}`}>{bar.value} {chart.unit}</span>
                  </div>
                  <div class="h-9 rounded-xl relative overflow-hidden" style="background: var(--color-surface)">
                    <div
                      class="h-full rounded-xl flex items-center justify-end pr-3 transition-all duration-700"
                      style={`width: ${pct}%; background: ${bar.color}; min-width: 8px`}
                    />
                  </div>
                </div>
              );
            })}
          </div>
          <p class="text-xs mt-6" style="color: var(--color-muted)">Sources: IRENA Renewable Power Generation Costs 2024; IEA World Energy Outlook 2024; JRC European Commission data</p>
        </div>
      </div>
    </section>

    <!-- ── CTA ────────────────────────────────────────────────── -->
    <section
      class="py-24 lg:py-28 relative overflow-hidden"
      style={`background: var(--color-dark)`}
    >
      <div
        class="absolute inset-0 opacity-10"
        style={`background: radial-gradient(ellipse at 70% 50%, ${accent} 0%, transparent 60%)`}
      />
      <div class="relative z-10 max-w-3xl mx-auto px-6 lg:px-10 text-center">
        <span
          class="inline-block px-4 py-1.5 rounded-full text-sm font-600 mb-6"
          style={`background: ${accentLight}; color: ${accentDark}`}
        >Start Your Project</span>
        <h2 class="text-4xl md:text-5xl font-800 mb-6 leading-snug text-white">
          Ready to invest in<br />{title}?
        </h2>
        <p class="text-lg mb-10" style="color: rgba(255,255,255,0.65)">
          Our team will assess your site, model the financials and guide you through every step — from feasibility to full operation.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/#contact"
            class="px-8 py-4 rounded-full text-sm font-600 text-white transition-all hover:scale-105 hover:shadow-lg"
            style={`background: ${accent}`}
          >
            Get a Free Assessment →
          </a>
          <a
            href="/#services"
            class="px-8 py-4 rounded-full text-sm font-600 transition-all hover:scale-105"
            style="background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.2)"
          >
            Explore Other Services
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
